---
import Layout from '../layouts/Layout.astro';
import '../styles/landing.css';

const featureCards = [
	{
		title: 'Создавайте программы',
		description:
			'Групповые, частные, разовые и соревновательные форматы с пробным периодом, длительностью и понятной моделью оплаты.',
		accent: 'Программы',
	},
	{
		title: 'Ведите клиентов',
		description:
			'Статусы, активность, выполнение, настроение, энергия и приглашения в программы в одном рабочем пространстве.',
		accent: 'Клиенты',
	},
	{
		title: 'Собирайте результаты',
		description:
			'Замеры, оценки, сравнение прогресса и соревновательные механики, которые удерживают вовлечённость.',
		accent: 'Прогресс',
	},
	{
		title: 'Принимайте оплаты',
		description:
			'Подписки, разовые платежи, пробный доступ, купоны и история оплат без отдельного набора сервисов.',
		accent: 'Оплаты',
	},
	{
		title: 'Общайтесь внутри платформы',
		description:
			'Сообщения, уведомления, приветственные сценарии и входящие клиента, чтобы не дробить коммуникацию.',
		accent: 'Коммуникации',
	},
	{
		title: 'Продавайте через витрину',
		description:
			'Публичная страница тренера с программами, товарами, описанием, контактами и понятным путём к покупке.',
		accent: 'Витрина',
	},
];

const audiences = [
	{
		title: 'Персональный тренер',
		description: 'Продавайте частные и групповые программы, ведите клиентов и собирайте оплату без ручной рутины.',
	},
	{
		title: 'Онлайн-коуч',
		description: 'Работайте удалённо, сопровождайте клиентов по календарю и масштабируйте подписочную модель.',
	},
	{
		title: 'Студия / команда тренеров',
		description: 'Стандартизируйте программы, управляйте клиентской базой и держите коммерцию в одном контуре.',
	},
];

const steps = [
	{
		number: '01',
		title: 'Создайте программу',
		description: 'Добавьте описание, формат, цену, длительность, контент и правила доступа.',
	},
	{
		number: '02',
		title: 'Пригласите клиентов',
		description: 'Подключайте по прямой ссылке или работайте со своей базой клиентов.',
	},
	{
		number: '03',
		title: 'Сопровождайте процесс',
		description: 'Календарь, сообщения, уведомления, выполнение, замеры и соревнования в одном цикле работы.',
	},
	{
		number: '04',
		title: 'Масштабируйте продажи',
		description: 'Развивайте витрину тренера, повторные оплаты, товары и подписки без новой сборки процессов.',
	},
];

const revenueCards = [
	'Подписки и разовые продажи',
	'Публичная витрина тренера',
	'Программы, товары и специальные предложения',
];

const coachSide = ['Программы', 'Клиенты', 'Замеры', 'Сообщения', 'Витрина', 'Оплаты'];
const clientSide = ['Календарь', 'Активные программы', 'Результаты', 'Входящие', 'История оплат', 'Профиль'];

const stories = [
	{
		title: 'Запуск онлайн-сопровождения',
		text: 'Соберите первую программу, откройте доступ по ссылке и принимайте оплату без внешних сервисов.',
	},
	{
		title: 'Продажа цифрового продукта',
		text: 'Оформите витрину тренера и продавайте готовые программы, товары и спецпредложения.',
	},
	{
		title: 'Работа со студией',
		text: 'Ведите общую клиентскую базу, унифицируйте сценарии сопровождения и контролируйте повторные продажи.',
	},
];

const faqs = [
	{
		question: 'Кому подходит TopTrainers?',
		answer:
			'Персональным тренерам, онлайн-коучам, фитнес-студиям и небольшим командам тренеров, которым нужен единый сервис для ведения клиентов, продажи программ и приёма оплат.',
	},
	{
		question: 'Можно ли продавать тренировочные программы онлайн?',
		answer:
			'Да. Платформа поддерживает продажу программ, товаров, разовых предложений и подписок. Публичная витрина тренера позволяет принимать заказы напрямую без сторонних сервисов.',
	},
	{
		question: 'Как клиент получает доступ к программе?',
		answer:
			'Клиент получает приглашение по прямой ссылке и открывает личный кабинет с календарём тренировок, активными программами, результатами замеров, сообщениями и историей оплат.',
	},
	{
		question: 'Подходит ли платформа для фитнес-студии или команды тренеров?',
		answer:
			'Да. TopTrainers поддерживает формат студии и команды: общая клиентская база, стандартизированные программы и централизованное управление оплатами.',
	},
	{
		question: 'Нужно ли устанавливать приложение?',
		answer:
			'Нет. TopTrainers работает в браузере на любом устройстве — тренер управляет кабинетом с компьютера или смартфона, клиент открывает программы без скачивания приложения.',
	},
	{
		question: 'Сколько стоит TopTrainers?',
		answer:
			'Начать работу можно бесплатно: создать первую программу, пригласить клиентов и настроить приём оплат. Актуальные тарифы доступны на платформе при регистрации.',
	},
];
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((faq) => ({
		'@type': 'Question',
		name: faq.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: faq.answer,
		},
	})),
};
---

<Layout
	title="TopTrainers — платформа для персональных тренеров и фитнес-коучей"
	description="Онлайн-сервис для персональных тренеров, фитнес-коучей и студий: ведение клиентов, продажа тренировочных программ, приём оплат и витрина тренера. Бесплатный старт."
>
	<Fragment slot="head">
		<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	</Fragment>
	<div class="page-shell">
		<header class="site-header">
			<div class="container header-row">
				<a class="brand" href="#top"><span class="brand-wordmark"><span class="brand-top">Top</span><span class="brand-rest">Trainers.ru</span></span></a>
				<nav class="main-nav">
					<a href="#features">Возможности</a>
					<a href="#audience">Для кого</a>
					<a href="#flow">Как это работает</a>
					<a href="#faq">FAQ</a>
				</nav>
				<div class="header-actions">
					<a class="button ghost" href="#demo">Посмотреть демо</a>
					<a class="button primary" href="#cta">Начать бесплатно</a>
				</div>
				<details class="mobile-menu">
					<summary class="mobile-menu-toggle" aria-label="Открыть меню">
						<span></span>
						<span></span>
						<span></span>
					</summary>
					<div class="mobile-menu-panel">
						<nav class="mobile-nav">
							<a href="#features">Возможности</a>
							<a href="#audience">Для кого</a>
							<a href="#flow">Как это работает</a>
							<a href="#faq">FAQ</a>
						</nav>
						<div class="mobile-menu-actions">
							<a class="button ghost" href="#demo">Посмотреть демо</a>
							<a class="button primary" href="#cta">Начать бесплатно</a>
						</div>
					</div>
				</details>
			</div>
		</header>

		<main id="top">
			<section class="hero-section">
				<div class="container hero-grid">
					<div class="hero-copy">
						<span class="eyebrow">Сервис для персональных тренеров, онлайн-коучей и фитнес-студий</span>
						<h1>
							<span class="brand-inline"><span class="brand-top">Top</span><span class="brand-rest">Trainers</span></span> — платформа для тренеров, где можно вести клиентов, продавать
							тренировочные программы и развивать <span>фитнес-бизнес онлайн</span>
						</h1>
						<p class="hero-text">
							Создавайте тренировочные программы, подключайте клиентов по ссылке,
							отслеживайте прогресс и замеры, принимайте оплаты онлайн и оформляйте
							собственную витрину тренера — всё в одном сервисе.
						</p>
						<div class="hero-actions">
							<a class="button primary large" href="#cta">Начать бесплатно</a>
							<a class="button secondary large" href="#demo">Посмотреть демо</a>
						</div>
					</div>

					<div class="hero-visual" aria-label="Примеры интерфейсов TopTrainers">
						<div class="hero-window-stack">
							<article class="hero-window trainer-window">
								<div class="hero-window-top">
									<div>
										<p class="mockup-label">Для тренера</p>
										<h3>Кабинет тренера</h3>
									</div>
									<span class="status-pill success">14 активных клиентов</span>
								</div>
								<div class="mini-chart">
									<span style="height: 52%"></span>
									<span style="height: 76%"></span>
									<span style="height: 64%"></span>
									<span style="height: 88%"></span>
								</div>
								<div class="mini-stats">
									<div>
										<strong>82%</strong>
										<span>выполнение недели</span>
									</div>
									<div>
										<strong>6</strong>
										<span>новых оплат</span>
									</div>
								</div>
							</article>

							<article class="hero-window client-window">
								<p class="mockup-label">Для клиента</p>
								<h3>Экран клиента</h3>
								<div class="client-calendar">
									<span>Пн</span><span>Вт</span><span>Ср</span><span>Чт</span><span>Пт</span><span>Сб</span><span>Вс</span>
									<b></b><b class="active"></b><b></b><b></b><b class="active"></b><b></b><b></b>
								</div>
								<div class="client-program-card">
									<strong>Сила / неделя 4</strong>
									<span>Следующая тренировка завтра в 09:00</span>
								</div>
							</article>

							<article class="hero-window payment-window">
								<p class="mockup-label">Оплаты</p>
								<h3>Окно приема оплаты</h3>
								<div class="payment-summary-row">
									<span>Подписка Pro Coach</span>
									<strong>4 900 RUB</strong>
								</div>
								<div class="payment-method">
									<div class="card-chip"></div>
									<div>
										<strong>Visa 2048</strong>
										<span>Автосписание включено</span>
									</div>
								</div>
								<a class="button primary hero-pay-button" href="#cta">Оплатить</a>
							</article>
						</div>
					</div>
				</div>
			</section>

			<section class="trust-bar">
				<div class="container trust-grid">
					<div>
						<p>Для онлайн-тренеров, фитнес-коучей и студий</p>
					</div>
					<div>
						<p>Программы, клиенты, оплаты и витрина в одном месте</p>
					</div>
					<div>
						<p>Быстрый старт без долгой настройки</p>
					</div>
				</div>
			</section>

			<section class="content-section" id="features">
				<div class="container">
					<div class="section-heading">
						<span class="eyebrow dark">Что можно делать в <span class="brand-inline"><span class="brand-top">Top</span><span class="brand-rest">Trainers</span></span></span>
						<h2>Возможности, собранные вокруг результата тренера, а не длинного списка модулей</h2>
						<p>
							Платформа закрывает основной цикл работы: запуск программы, ведение клиента,
							коммуникации, прогресс и продажи.
						</p>
					</div>
					<div class="feature-grid">
						{featureCards.map((card) => (
							<article class="feature-card">
								<span class="feature-accent">{card.accent}</span>
								<h3>{card.title}</h3>
								<p>{card.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="content-section alt" id="audience">
				<div class="container">
					<div class="section-heading compact">
						<span class="eyebrow dark">Для кого</span>
						<h2>Быстро понятно, как <span class="brand-inline"><span class="brand-top">Top</span><span class="brand-rest">Trainers</span></span> встраивается в ваш формат работы</h2>
					</div>
					<div class="audience-grid">
						{audiences.map((item) => (
							<article class="audience-card">
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="content-section" id="flow">
				<div class="container">
					<div class="section-heading">
						<span class="eyebrow dark">Как это работает</span>
						<h2>Простой путь от первой программы до повторных продаж</h2>
						<p><span class="brand-inline"><span class="brand-top">Top</span><span class="brand-rest">Trainers</span></span> связывает coaching и commerce в одну понятную операционную модель.</p>
					</div>
					<div class="steps-grid">
						{steps.map((step) => (
							<article class="step-card">
								<span class="step-number">{step.number}</span>
								<h3>{step.title}</h3>
								<p>{step.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="content-section revenue-section">
				<div class="container revenue-grid">
					<div class="section-heading compact inverse">
						<span class="eyebrow">Рост бизнеса</span>
						<h2>Не просто ведите клиентов - развивайте тренерский бизнес</h2>
						<p>
							<span class="brand-inline"><span class="brand-top">Top</span><span class="brand-rest">Trainers</span></span> помогает продавать не только персональное сопровождение, но и
							масштабируемые цифровые продукты.
						</p>
					</div>
					<div class="revenue-cards">
						{revenueCards.map((item) => (
							<article class="revenue-card">
								<h3>{item}</h3>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="content-section">
				<div class="container split-grid">
					<article class="split-card dark-surface">
						<span class="eyebrow">Для тренера</span>
						<h2>Тренеру удобно</h2>
						<ul class="capability-list">
							{coachSide.map((item) => <li>{item}</li>)}
						</ul>
					</article>
					<article class="split-card light-surface">
						<span class="eyebrow dark">Для клиента</span>
						<h2>Клиенту понятно</h2>
						<ul class="capability-list light">
							{clientSide.map((item) => <li>{item}</li>)}
						</ul>
					</article>
				</div>
			</section>

			<section class="content-section alt">
				<div class="container brand-grid">
					<div class="section-heading compact">
						<span class="eyebrow dark">Ваш бренд</span>
						<h2>Ваш бренд - на первом плане</h2>
						<p>
							Оформите витрину тренера, добавьте фото, описание, контакты, программы и товары.
							Клиент видит не безликий сервис, а ваш собственный coaching-продукт.
						</p>
					</div>
					<article class="brand-card">
						<div class="brand-preview-header">
							<div class="avatar large"></div>
							<div>
								<strong>Тренер Алексей Орлов</strong>
								<span>Растяжка · Онлайн + Зал</span>
							</div>
						</div>
						<div class="brand-preview-body">
							<div class="badge-line">
								<span>Публичная витрина</span>
								<span>Программы</span>
								<span>Товары</span>
							</div>
							<div class="brand-panel">
								<strong>Move better. Train stronger.</strong>
								<p>Групповые программы, сопровождение и цифровые продукты в одном брендовом пространстве.</p>
							</div>
						</div>
					</article>
				</div>
			</section>

			<section class="content-section" id="demo">
				<div class="container">
					<div class="section-heading compact">
						<span class="eyebrow dark">Сценарии запуска</span>
						<h2>Что можно запустить за 1 день</h2>
						<p>Пока реальные кейсы формируются, лендинг показывает самые понятные сценарии применения.</p>
					</div>
					<div class="stories-grid">
						{stories.map((story) => (
							<article class="story-card">
								<h3>{story.title}</h3>
								<p>{story.text}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="content-section alt" id="faq">
				<div class="container faq-grid">
					<div class="section-heading compact">
						<span class="eyebrow dark">FAQ</span>
						<h2>Частые вопросы о платформе для тренеров</h2>
					</div>
					<div class="faq-list">
						{faqs.map((item) => (
							<details class="faq-item">
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))}
					</div>
				</div>
			</section>

			<section class="bottom-cta" id="cta">
				<div class="container bottom-cta-inner">
					<div>
						<span class="eyebrow">Начните прямо сейчас</span>
						<h2>Запустите тренерский бизнес в <span class="brand-inline"><span class="brand-top">Top</span><span class="brand-rest">Trainers</span></span></h2>
						<p>
							Создайте первую тренировочную программу, пригласите клиентов и настройте
							приём оплат онлайн — без долгой настройки и лишних сервисов.
						</p>
					</div>
					<div class="hero-actions bottom">
						<a class="button primary large" href="#top">Начать бесплатно</a>
						<a class="button secondary large" href="#demo">Запросить демо</a>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="container footer-row">
				<p>&copy; 2026 <span class="brand-inline"><span class="brand-top">Top</span><span class="brand-rest">Trainers</span></span></p>
				<div>
					<a href="#features">Возможности</a>
					<a href="#flow">Как это работает</a>
					<a href="#faq">FAQ</a>
				</div>
			</div>
		</footer>
	</div>
</Layout>

<style>
	.brand-wordmark,
	.brand-inline {
		display: inline-flex;
		align-items: baseline;
		gap: 0;
	}

	.brand-top {
		color: var(--color-accent);
	}

	.brand-rest {
		color: inherit;
	}

	.page-shell {
		overflow-x: clip;
	}

	.container {
		width: min(calc(100% - 32px), var(--container));
		margin: 0 auto;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: none;
		background: transparent;
		border-bottom: none;
	}

	.site-header::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		backdrop-filter: blur(18px);
		background: rgba(15, 23, 42, 0.72);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		pointer-events: none;
	}

	.header-row,
	.footer-row,
	.mockup-top,
	.metric-row,
	.client-row,
	.price-row,
	.payment-card,
	.brand-preview-header,
	.brand-preview-body,
	.bottom-cta-inner {
		display: flex;
		justify-content: space-between;
		gap: 16px;
